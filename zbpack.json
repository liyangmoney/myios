{
  "name": "myios",
  "services": [
    {
      "name": "frontend",
      "type": "static",
      "build": {
        "root": "frontend",
        "output": "dist"
      },
      "env": [
        "VITE_API_BASE_URL"
      ]
    },
    {
      "name": "backend",
      "type": "docker",
      "build": {
        "dockerfile": "backend/Dockerfile"
      },
      "env": [
        "DB_HOST",
        "DB_PORT",
        "DB_USER",
        "DB_PASSWORD",
        "DB_NAME",
        "JWT_SECRET",
        "JWT_EXPIRES_IN",
        "EMAIL_USER",
        "EMAIL_PASS",
        "EMAIL_FROM_NAME",
        "APP_URL",
        "PORT",
        "UPLOAD_PATH",
        "MAX_FILE_SIZE"
      ]
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/backend/api/$1"
    },
    {
      "src": "/uploads/(.*)",
      "dest": "/backend/uploads/$1"
    }
  ]
}
